# arr-mcp configuration for the local containerized test stack.
# Copy to .env (scripts/test-stack.sh does this automatically on first run).

ARR_MCP_API_KEY=test-key-local
ARR_MCP_PORT=8081

# arr-mcp runs as a container alongside the test services on "test-net" —
# reach them by container hostname, not localhost.
ARR_MCP_CONTAINER_RUNTIME=docker
ARR_MCP_SOCKET_PATH=unix:///var/run/docker.sock

ARR_MCP_SERVICES_DIR=/data
ARR_MCP_MEDIA_DIR=/data/media

# Dashboard auth (see ADR-0008) — throwaway values for local testing only.
ARR_MCP_SESSION_SECRET=test-session-secret-change-me
ARR_MCP_ADMIN_USERS=admin

ARR_MCP_LOG_LEVEL=info
