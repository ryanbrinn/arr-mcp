# arr-mcp configuration — copy to .env and edit

# REQUIRED: change before deploying
ARR_MCP_API_KEY=changeme

# Port the MCP HTTP server listens on
ARR_MCP_PORT=8081

# Directory containing podman-compose stack folders
ARR_MCP_STACKS_DIR=/opt/stacks

# Root of media file storage
ARR_MCP_MEDIA_DIR=/media-server

# Container runtime: auto | docker | podman
# auto detects rootless Podman socket first, then Docker
ARR_MCP_CONTAINER_RUNTIME=auto

# Logging level: debug | info | warning | error
ARR_MCP_LOG_LEVEL=info
